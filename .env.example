# Required (set to a real key for production; not needed when MOCK_AI=true)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local development mock — set to true to skip Claude API calls entirely
MOCK_AI=false

# Claude API settings
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=600
CLAUDE_TEMPERATURE=0.9
CLAUDE_TEMPERATURE_REGEN=1.0
CLAUDE_TIMEOUT_MS=15000

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=60
MAX_DAILY_CLAUDE_CALLS=10000

# Content safety
BLOCKLIST_PATH=./config/blocklist.txt

# Server
NODE_ENV=development
